# Lighter.xyz API endpoint (mainnet)
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai

# Your Ethereum wallet private key.
# Used locally by find_account_index.py to derive your L1 address. Never share or commit this.
PRIVATE_KEY=your_eth_private_key_here

# Lighter API key private key (created via the Lighter SDK / app). Used to sign orders.
LIGHTER_API_KEY_PRIVATE=your_lighter_api_key_private_here

# Your Lighter account index. Run `python find_account_index.py` to discover it.
LIGHTER_ACCOUNT_INDEX=0

# Lighter API key index (default 10).
LIGHTER_API_KEY_INDEX=10
